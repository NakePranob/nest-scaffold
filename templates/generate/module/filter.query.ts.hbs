import { SelectQueryBuilder } from 'typeorm';
import { {{entityName}} } from '../entities/{{entityFile}}.entity';
import { BaseFilterQuery } from '{{commonFromNested}}/helpers/base-filter.query';

export class {{entityName}}FilterQuery extends BaseFilterQuery<{{entityName}}> {
  constructor(qb: SelectQueryBuilder<{{entityName}}>) {
    super(qb);
  }

  bySearch(search?: string) {
    if (search) {
      this.qb.andWhere(`${this.qb.alias}.name ILIKE :search`, {
        search: `%${search}%`,
      });
    }
    return this;
  }
}
