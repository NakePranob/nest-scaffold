import { Module } from '@nestjs/common';
{{#if hasTypeorm}}
import { TypeOrmModule } from '@nestjs/typeorm';
{{#if isMicroservice}}
import { {{entityName}} } from './domain/entities/{{entityFile}}.entity';
{{else}}
import { {{entityName}} } from './entities/{{entityFile}}.entity';
{{/if}}
{{/if}}
{{#if hasController}}
{{#if isMicroservice}}
import { {{pascalName}}Controller } from './infrastructure/{{fileBase}}.controller.grpc';
{{else}}
import { {{pascalName}}Controller } from './{{fileBase}}.controller';
{{/if}}
{{/if}}
{{#if hasService}}
{{#if isMicroservice}}
import { {{pascalName}}Service } from './application/{{fileBase}}.service';
{{else}}
import { {{pascalName}}Service } from './{{fileBase}}.service';
{{/if}}
{{/if}}

@Module({
  imports: [{{#if hasTypeorm}}TypeOrmModule.forFeature([{{entityName}}]){{/if}}],
  {{#if hasController}}controllers: [{{pascalName}}Controller],{{/if}}
  {{#if hasService}}providers: [{{pascalName}}Service],
  exports: [{{pascalName}}Service],{{/if}}
})
export class {{moduleClass}} {}
