import { Injectable } from '@nestjs/common';
{{#if hasTypeorm}}
import { InjectRepository } from '@nestjs/typeorm';
import { Repository } from 'typeorm';
import { {{entityName}} } from './entities/{{entityFile}}.entity';
{{/if}}
import { Create{{entityName}}Dto } from './dto/create-{{entityFile}}.dto';
import { Update{{entityName}}Dto } from './dto/update-{{entityFile}}.dto';
{{#if hasPagination}}
import { Search{{entityName}}Dto } from './dto/search-{{entityFile}}.dto';
import { {{entityName}}FilterQuery } from './queries/{{entityFile}}-filter.query';
import { PaginatedResult } from '{{commonFromModule}}/interfaces/paginated-result.interface';
{{/if}}
{{#if hasEnvelope}}
import { AppException } from '{{commonFromModule}}/helpers/app-exception';
{{#if hasTypeorm}}
import { isUniqueConstraintError } from '{{commonFromModule}}/helpers/database-error';
{{/if}}
import { {{errorPrefix}}_ERRORS } from './{{entityFile}}-error-catalog';
{{/if}}

@Injectable()
export class {{pascalName}}Service {
  constructor(
{{#if hasTypeorm}}
    @InjectRepository({{entityName}})
    private readonly repo: Repository<{{entityName}}>,
{{/if}}
  ) {}

{{#if hasTypeorm}}
  async create(dto: Create{{entityName}}Dto): Promise<{{entityName}}> {
    const entity = this.repo.create(dto);
    try {
      return await this.repo.save(entity);
    } catch (error) {
{{#if hasEnvelope}}
      if (isUniqueConstraintError(error)) {
        throw AppException.from({{errorPrefix}}_ERRORS.{{errorPrefix}}_ALREADY_EXISTS);
      }
{{/if}}
      throw error;
    }
  }

{{#if hasPagination}}
  async findAll(dto: Search{{entityName}}Dto): Promise<PaginatedResult<{{entityName}}>> {
    const qb = this.repo.createQueryBuilder('{{queryAlias}}');
    const page = dto.page!;
    const limit = dto.limit!;
    return new {{entityName}}FilterQuery(qb)
      .bySearch(dto.search)
      .withPagination(page, limit)
      .withDefaultOrder()
      .execPaginated(page, limit);
  }
{{else}}
  async findAll(): Promise<{{entityName}}[]> {
    return this.repo.find();
  }
{{/if}}

  async findById(id: string): Promise<{{entityName}}> {
    const entity = await this.repo.findOneBy({ id });
{{#if hasEnvelope}}
    if (!entity) throw AppException.from({{errorPrefix}}_ERRORS.{{errorPrefix}}_NOT_FOUND);
{{/if}}
    return entity;
  }

  async update(id: string, dto: Update{{entityName}}Dto): Promise<{{entityName}}> {
    await this.repo.update(id, dto);
    return this.findById(id);
  }

  async delete(id: string): Promise<void> {
    const result = await this.repo.delete(id);
{{#if hasEnvelope}}
    if (result.affected === 0) {
      throw AppException.from({{errorPrefix}}_ERRORS.{{errorPrefix}}_NOT_FOUND);
    }
{{/if}}
  }
{{else}}
  create(dto: Create{{entityName}}Dto) {
    return dto;
  }
{{/if}}
}
