import { IsOptional, IsString } from 'class-validator';
import { PaginationDto } from '{{commonFromNested}}/dto/pagination.dto';
{{#if hasSwagger}}
import { ApiPropertyOptional } from '@nestjs/swagger';
{{/if}}

export class Search{{entityName}}Dto extends PaginationDto {
{{#if hasSwagger}}
  @ApiPropertyOptional({ example: 'search term' })
{{/if}}
  @IsOptional()
  @IsString()
  search?: string;
}
