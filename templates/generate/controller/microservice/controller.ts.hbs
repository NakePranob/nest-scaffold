import { Controller } from '@nestjs/common';
{{#if hasService}}
import { GrpcMethod } from '@nestjs/microservices';
import { {{pascalName}}Service } from './{{fileBase}}.service';
import { Update{{entityName}}Dto } from './dto/update-{{entityFile}}.dto';
{{/if}}

@Controller()
export class {{pascalName}}Controller {
  {{#if hasService}}
  constructor(private readonly {{camelName}}Service: {{pascalName}}Service) {}

  @GrpcMethod('{{pascalName}}Service', 'FindAll')
  findAll(dto: Record<string, never>) {
    return this.{{camelName}}Service.findAll(dto);
  }

  @GrpcMethod('{{pascalName}}Service', 'FindById')
  findById(dto: { id: string }) {
    return this.{{camelName}}Service.findById(dto.id);
  }

  @GrpcMethod('{{pascalName}}Service', 'Update')
  update(dto: Update{{entityName}}Dto & { id: string }) {
    const { id, ...data } = dto;
    return this.{{camelName}}Service.update(id, data);
  }

  @GrpcMethod('{{pascalName}}Service', 'Delete')
  delete(dto: { id: string }) {
    return this.{{camelName}}Service.delete(dto.id);
  }
  {{else}}
  constructor() {}
  {{/if}}
}
