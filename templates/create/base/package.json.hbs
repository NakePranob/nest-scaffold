{
  "name": "{{projectName}}",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"{{#if e2e}},
    "test:e2e": "jest --config ./test/jest-e2e.json"{{/if}}{{#if seeds}},
    "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts"{{/if}}
  },
  "dependencies": {
    "@nestjs/common": "{{stack.nestCommon}}",
    "@nestjs/config": "{{stack.nestConfig}}",
    "@nestjs/core": "{{stack.nestCore}}",
    "@nestjs/platform-fastify": "{{stack.nestPlatformFastify}}"{{#if swagger}},
    "@fastify/static": "{{stack.fastifyStatic}}",
    "@nestjs/swagger": "{{stack.nestSwagger}}"{{/if}}{{#if typeorm}},
    "@nestjs/typeorm": "{{stack.nestTypeorm}}",
    "pg": "{{stack.pg}}",
    "typeorm": "{{stack.typeorm}}"{{/if}}{{#if auth}},
    "@nestjs/jwt": "{{stack.nestJwt}}",
    "@nestjs/passport": "{{stack.nestPassport}}",
    "passport": "{{stack.passport}}",
    "passport-jwt": "{{stack.passportJwt}}"{{/if}},
    "class-transformer": "{{stack.classTransformer}}",
    "class-validator": "{{stack.classValidator}}",
    "fastify": "{{stack.fastify}}",
    "reflect-metadata": "{{stack.reflectMetadata}}",
    "rxjs": "{{stack.rxjs}}"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "{{stack.nestCli}}",
    "@nestjs/schematics": "{{stack.nestSchematics}}",
    "@nestjs/testing": "{{stack.nestTesting}}",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0"{{#if auth}},
    "@types/passport-jwt": "^4.0.1"{{/if}},
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "{{stack.jest}}",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "{{stack.tsJest}}",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "{{stack.typescript}}",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
