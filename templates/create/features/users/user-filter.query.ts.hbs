import { SelectQueryBuilder } from 'typeorm';
import { User } from '../entities/user.entity';
import { BaseFilterQuery } from '{{commonFromNested}}/helpers/base-filter.query';

export class UserFilterQuery extends BaseFilterQuery<User> {
  constructor(qb: SelectQueryBuilder<User>) {
    super(qb);
  }

  bySearch(search?: string) {
    if (search) {
      this.qb.andWhere(`${this.qb.alias}.name ILIKE :search`, { search: `%${search}%` });
    }
    return this;
  }

  byRole(role?: string) {
    if (role) {
      this.qb.andWhere(`${this.qb.alias}.role = :role`, { role });
    }
    return this;
  }

  byActive(isActive?: boolean) {
    if (isActive !== undefined) {
      this.qb.andWhere(`${this.qb.alias}.isActive = :isActive`, { isActive });
    }
    return this;
  }
}
