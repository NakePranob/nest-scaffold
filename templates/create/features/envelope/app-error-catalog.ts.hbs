import { HttpStatus } from '@nestjs/common';

export enum CommonErrorCode {
  InternalError = 'INTERNAL_ERROR',
  ValidationError = 'VALIDATION_ERROR',
  HttpError = 'HTTP_ERROR',
  Unauthorized = 'UNAUTHORIZED',
  Forbidden = 'FORBIDDEN',
  NotFound = 'NOT_FOUND',
  BadRequest = 'BAD_REQUEST',
  Conflict = 'CONFLICT',
}

export type ErrorDescriptor = {
  code: string;
  message: string;
  statusCode: number;
};

export const COMMON_ERRORS = {
  INTERNAL_ERROR: {
    code: CommonErrorCode.InternalError,
    message: 'Internal server error',
    statusCode: HttpStatus.INTERNAL_SERVER_ERROR,
  },
  VALIDATION_ERROR: {
    code: CommonErrorCode.ValidationError,
    message: 'Validation failed',
    statusCode: HttpStatus.BAD_REQUEST,
  },
  HTTP_ERROR: {
    code: CommonErrorCode.HttpError,
    message: 'HTTP error',
    statusCode: HttpStatus.BAD_REQUEST,
  },
  BAD_REQUEST: {
    code: CommonErrorCode.BadRequest,
    message: 'Bad request',
    statusCode: HttpStatus.BAD_REQUEST,
  },
  UNAUTHORIZED: {
    code: CommonErrorCode.Unauthorized,
    message: 'Unauthorized',
    statusCode: HttpStatus.UNAUTHORIZED,
  },
  FORBIDDEN: {
    code: CommonErrorCode.Forbidden,
    message: 'Forbidden',
    statusCode: HttpStatus.FORBIDDEN,
  },
  NOT_FOUND: {
    code: CommonErrorCode.NotFound,
    message: 'Resource not found',
    statusCode: HttpStatus.NOT_FOUND,
  },
  CONFLICT: {
    code: CommonErrorCode.Conflict,
    message: 'Conflict',
    statusCode: HttpStatus.CONFLICT,
  },
} as const satisfies Record<string, ErrorDescriptor>;

export function getHttpErrorDescriptor(statusCode: number): ErrorDescriptor {
  switch (statusCode) {
    case HttpStatus.BAD_REQUEST:
      return COMMON_ERRORS.BAD_REQUEST;
    case HttpStatus.UNAUTHORIZED:
      return COMMON_ERRORS.UNAUTHORIZED;
    case HttpStatus.FORBIDDEN:
      return COMMON_ERRORS.FORBIDDEN;
    case HttpStatus.NOT_FOUND:
      return COMMON_ERRORS.NOT_FOUND;
    case HttpStatus.CONFLICT:
      return COMMON_ERRORS.CONFLICT;
    default:
      return {
        ...COMMON_ERRORS.HTTP_ERROR,
        statusCode,
      };
  }
}
