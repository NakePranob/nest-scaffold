import { applyDecorators } from '@nestjs/common';
import { ApiBody, ApiOperation } from '@nestjs/swagger';
import {
  ApiConflictError,
  ApiDefaultErrors,
} from '{{commonFromNested}}/swagger/decorators/api-error-responses.decorator';
import { ApiSuccessResponse } from '{{commonFromNested}}/swagger/decorators/api-success-response.decorator';
import { AUTH_ERRORS } from '../auth-error-catalog';
import { LoginDto } from '../dto/login.dto';
import { RegisterDto } from '../dto/register.dto';
import { AuthTokenResponseDto } from './auth-response.dto';

export function ApiRegisterDocs() {
  return applyDecorators(
    ApiOperation({ summary: 'Register a new user' }),
    ApiBody({ type: RegisterDto }),
    ApiSuccessResponse(AuthTokenResponseDto),
    ApiConflictError(
      AUTH_ERRORS.EMAIL_ALREADY_IN_USE.code,
      AUTH_ERRORS.EMAIL_ALREADY_IN_USE.message,
    ),
    ApiDefaultErrors(),
  );
}

export function ApiLoginDocs() {
  return applyDecorators(
    ApiOperation({ summary: 'Login with email and password' }),
    ApiBody({ type: LoginDto }),
    ApiSuccessResponse(AuthTokenResponseDto),
    ApiDefaultErrors(),
  );
}
