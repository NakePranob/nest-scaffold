import { Injectable } from '@nestjs/common';
import { AuthGuard } from '@nestjs/passport';
import { COMMON_ERRORS } from '../errors/app-error-catalog';
import { AppException } from '../helpers/app-exception';

@Injectable()
export class JwtAuthGuard extends AuthGuard('jwt') {
  handleRequest<TUser = unknown>(err: unknown, user: TUser) {
    if (err || !user) {
      throw AppException.from(COMMON_ERRORS.UNAUTHORIZED);
    }

    return user;
  }
}
