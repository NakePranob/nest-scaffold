{
  "name": "@nakedev/nest-scaffold",
  "version": "0.3.3",
  "description": "Scaffold NestJS modular backend projects with selectable features",
  "bin": {
    "nest-scaffold": "./bin/nest-scaffold.js"
  },
  "files": [
    "dist",
    "templates",
    "bin",
    "stack-packages.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm run verify",
    "test:method": "node scripts/test-method-generator.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "check:stack": "node scripts/check-stack-updates.mjs",
    "verify": "pnpm run build && pnpm run test:method && NEST_SCAFFOLD_SKIP_INSTALL=1 pnpm run test:smoke"
  },
  "keywords": [
    "nestjs",
    "scaffold",
    "cli",
    "generator"
  ],
  "author": "nakedev",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.4",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
